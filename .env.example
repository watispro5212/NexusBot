# Nexus Protocol — copy to .env and fill in values (never commit .env)

# Required: Discord bot token
TOKEN=

# Required for slash command deploy and /invite link (Application ID in Developer Portal)
DISCORD_CLIENT_ID=

# Optional alias some setups use
# CLIENT_ID=

# Required: MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=

# Optional: register commands to a single guild instantly while developing
# GUILD_ID=

# Optional: HTTP port for static site + API (default 3000)
# PORT=3000
